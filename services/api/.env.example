# Cloud Run API configuration
# Copy to .env and fill in values for local development.

# Port for the Express server (Cloud Run sets this automatically)
PORT=8080

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,https://cloud-flood.web.app,https://cloud-flood.firebaseapp.com

# Path to Firebase service account key JSON (for local development only).
# On Cloud Run, credentials are provided automatically via the service account.
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
