rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Leaderboard scores ─────────────────────────────
    // Path: leaderboards/{dateKey}/scores/{uid}
    match /leaderboards/{dateKey}/scores/{uid} {
      // Only authenticated users can read leaderboard scores
      allow read: if request.auth != null;

      // Only the authenticated owner can write their own score
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.data.moves is int
                   && request.resource.data.moves > 0;
    }

    // ── User score history ─────────────────────────────
    // Path: users/{uid}/scores/{dateKey}
    match /users/{uid}/scores/{dateKey} {
      // Only the owner can read their own scores
      allow read: if request.auth != null
                  && request.auth.uid == uid;

      // Only the owner can write their own scores
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.data.moves is int
                   && request.resource.data.moves > 0;
    }
  }
}
