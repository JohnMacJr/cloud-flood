# Firebase configuration
# Copy this file to .env and fill in your Firebase project values.
# Find these values in the Firebase Console → Project Settings → General → Your apps → Web app.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloud Run API base URL (no trailing slash)
# Local development: http://localhost:8080
# Production: https://your-cloud-run-service-url
VITE_API_BASE_URL=http://localhost:8080
